<!DOCTYPE html>
<html>
<head>
    <title>My Applications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">Internship Tracker</a>
            <div>
                <a href="/applications/add" class="btn btn-success btn-sm">+ Add</a>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h2>My Applications</h2>
        
        <% if (applications.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead class="table-dark">
                        <tr><th>Company</th><th>Position</th><th>Status</th><th>Date</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% applications.forEach(app => { %>
                            <tr>
                                <td><%= app.company_name %></td>
                                <td><%= app.position %></td>
                                <td><span class="badge bg-info"><%= app.status %></span></td>
                                <td><%= new Date(app.created_at).toLocaleDateString() %></td>
                                <td>
                                    <a href="/applications/<%= app.id %>/edit" class="btn btn-warning btn-sm">Edit</a>
                                    <form method="POST" action="/applications/<%= app.id %>/delete" style="display:inline">
                                        <button class="btn btn-danger btn-sm" onclick="return confirm('Delete?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info">No applications yet. <a href="/applications/add">Add your first application</a></div>
        <% } %>
    </div>
</body>
</html>