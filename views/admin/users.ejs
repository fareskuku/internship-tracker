<%
let body = `
<h2><i class="fas fa-users"></i> Manage Users</h2>
<div class="card mt-3"><div class="card-body">
    <table class="table"><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Action</th></tr></thead><tbody>
        ${users.map(user => `
            <tr>
                <td>${user.fullname}</td><td>${user.email}</td>
                <td><span class="badge bg-${user.role === 'admin' ? 'danger' : user.role === 'advisor' ? 'warning' : 'info'}">${user.role}</span></td>
                <td><form method="POST" action="/admin/users/role" style="display:flex;gap:5px"><input type="hidden" name="userId" value="${user.id}">
                <select name="role" class="form-select form-select-sm" style="width:120px"><option value="student" ${user.role === 'student' ? 'selected' : ''}>Student</option><option value="advisor" ${user.role === 'advisor' ? 'selected' : ''}>Advisor</option><option value="admin" ${user.role === 'admin' ? 'selected' : ''}>Admin</option></select>
                <button type="submit" class="btn btn-sm btn-primary">Update</button></form></td>
            </tr>
        `).join('')}
    </tbody></table>
</div></div>
`;
%>
<%- include('../layouts/main') %>