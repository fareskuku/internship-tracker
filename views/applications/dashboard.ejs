<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container-fluid mt-4">
    <div class="welcome-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-2">Welcome back, <%= user ? user.fullname : 'Student' %>!</h2>
                <p class="mb-0 opacity-90">Track and manage all your internship applications in one place</p>
            </div>
            <a href="/applications/add" class="btn btn-light rounded-pill px-4">
                <i class="fas fa-plus me-2"></i> New Application
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card" onclick="window.location.href='/applications'">
                <div class="stat-icon total">
                    <i class="fas fa-briefcase"></i>
                </div>
                <div class="stat-value"><%= stats.total || 0 %></div>
                <div class="stat-label">Total Applications</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card pending">
                <div class="stat-icon pending">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-value"><%= stats.pending || 0 %></div>
                <div class="stat-label">Pending Review</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card interview">
                <div class="stat-icon interview">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="stat-value"><%= stats.interview || 0 %></div>
                <div class="stat-label">Interviews</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card offered">
                <div class="stat-icon offered">
                    <i class="fas fa-trophy"></i>
                </div>
                <div class="stat-value"><%= stats.offered || 0 %></div>
                <div class="stat-label">Offers Received</div>
            </div>
        </div>
    </div>

    <div class="recent-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i> Recent Applications</h5>
            <a href="/applications" class="text-decoration-none">View All <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        
        <% if (applications && applications.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Company</th>
                        <th>Position</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% applications.forEach(function(app) { %>
                    <tr>
                        <td><strong><%= app.company_name %></strong></td>
                        <td><%= app.position %></td>
                        <td><span class="badge-pending"><%= app.status %></span></td>
                        <td><%= new Date(app.created_at).toLocaleDateString() %></td>
                        <td><a href="/applications/<%= app.id %>/edit" class="btn btn-sm btn-outline-primary rounded-pill"><i class="fas fa-edit"></i></a></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
            <p class="text-muted mb-3">No applications yet. Start tracking your internship journey!</p>
            <a href="/applications/add" class="btn btn-primary rounded-pill px-4">Add Your First Application</a>
        </div>
        <% } %>
    </div>
</div>

<style>
.welcome-card {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border-radius: 24px;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
}
.stat-card {
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    transition: all 0.3s;
    cursor: pointer;
    border: 1px solid rgba(0,0,0,0.05);
}
.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 25px -12px rgba(0,0,0,0.15);
}
.stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 1rem;
}
.stat-icon.total { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; }
.stat-icon.pending { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
.stat-icon.interview { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
.stat-icon.offered { background: linear-gradient(135deg, #10b981, #059669); color: white; }
.stat-value {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
}
.stat-label {
    color: #64748b;
    font-size: 0.875rem;
}
.recent-card {
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
}
.badge-pending {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
}
</style>

<%- include('../partials/footer') %>