<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-list me-2"></i> My Applications</h2>
        <a href="/applications/add" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-2"></i> Add Application
        </a>
    </div>

    <% if (applications && applications.length > 0) { %>
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 py-3">Company</th>
                            <th class="border-0 py-3">Position</th>
                            <th class="border-0 py-3">Location</th>
                            <th class="border-0 py-3">Status</th>
                            <th class="border-0 py-3">Date</th>
                            <th class="border-0 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% applications.forEach(function(app) { %>
                        <tr>
                            <td class="py-3"><strong><%= app.company_name %></strong></td>
                            <td class="py-3"><%= app.position %></td>
                            <td class="py-3"><%= app.location || '-' %></td>
                            <td class="py-3">
                                <span class="badge-pending"><%= app.status %></span>
                            </td>
                            <td class="py-3"><%= new Date(app.created_at).toLocaleDateString() %></td>
                            <td class="py-3">
                                <a href="/applications/<%= app.id %>/edit" class="btn btn-sm btn-outline-warning rounded-pill me-1">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="POST" action="/applications/<%= app.id %>/delete" style="display:inline">
                                    <button class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Delete this application?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="text-center py-5 bg-white rounded-4 shadow-sm">
        <i class="fas fa-inbox fa-5x text-muted mb-4"></i>
        <h4 class="text-muted">No Applications Yet</h4>
        <p class="text-muted mb-4">Start tracking your internship applications today!</p>
        <a href="/applications/add" class="btn btn-primary rounded-pill px-4">Add Your First Application</a>
    </div>
    <% } %>
</div>

<style>
.badge-pending {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
}
</style>

<%- include('../partials/footer') %>